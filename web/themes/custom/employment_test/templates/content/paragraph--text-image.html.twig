{#
/**
 * @file
 * Theme override for the Text + Image Paragraph.
 */
#}

{% set image_position = paragraph.field_image_position.value|default('left') %}

{% set classes = [
  'paragraph',
  'paragraph--type--text-image',
  'text-image',
  'text-image--' ~ image_position|clean_class,
  view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
  not paragraph.isPublished() ? 'paragraph--unpublished',
] %}

<div{{ attributes.addClass(classes) }}>
  <div class="text-image__content">
    {{ content.field_text }}
  </div>

  <div class="text-image__media">
    {{ content.field_image }}
  </div>
</div>
