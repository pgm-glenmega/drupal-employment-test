# Composer dependencies
/vendor/

# Drupal core and Composer-installed extensions
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# Drupal environment-specific and generated files
/web/sites/*/settings*.php
!/web/sites/*/default.settings.php
/web/sites/*/services*.yml
!/web/sites/*/default.services.yml
/web/sites/*/files/
/web/sites/*/private/
/web/sites/simpletest/

# Frontend dependencies and generated assets
/node_modules/
npm-debug.log*
yarn-error.log*

# Local environment and editor files
.env
.env.*
!.env.example
.idea/
.vscode/
.DS_Store
Thumbs.db

# Track shared project settings; DDEV credentials remain in settings.ddev.php.
!/web/sites/default/settings.php
